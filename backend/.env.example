PORT=3001
NODE_ENV=development

# MongoDB Atlas — cole sua connection string aqui
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pokefolio

# JWT — gere valores aleatórios longos (ex: openssl rand -hex 64)
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=troque_por_outro_segredo_longo_e_aleatorio
JWT_REFRESH_EXPIRES_IN=30d

# Brevo (ex-Sendinblue) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=noreply@pokefolio.app
BREVO_FROM_NAME=Pokéfolio

# URL do frontend (para links nos emails)
FRONTEND_URL=http://localhost:8080
